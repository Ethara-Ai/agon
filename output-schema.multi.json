{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ethara.ai/schemas/question-bank-output.multi.schema.json",
  "title": "Consolidated (Multi-Project) Question Bank Output",
  "description": "One JSON output spanning multiple projects: question bank, grading, QC report, per-project quality and rubric, and one skillset. Image bytes are emitted as separate response parts; each media entry carries a media_id and an INITIALLY EMPTY url that the dev pipeline backfills with the S3 link after upload (binding image->entry by media_id, never by position).",
  "type": "object",
  "required": ["project", "question_bank", "question_bank_quality", "worker_grading_rubric", "skillset"],
  "additionalProperties": false,
  "properties": {
    "provenance": {
      "type": "object",
      "description": "Auditability for a hiring instrument: reproduce/trace any item to the run that made it.",
      "additionalProperties": false,
      "properties": {
        "bank_version": { "type": "string" },
        "generation_seed": { "type": "string" },
        "generator_model_id": { "type": "string" },
        "source_sop_ids": { "type": "array", "items": { "type": "string" } },
        "skillset_version": { "type": "string" }
      }
    },
    "project": {
      "type": "object",
      "required": ["name", "task_type", "arrangement", "settings", "projects"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "task_type": { "type": "string" },
        "arrangement": { "type": "string", "enum": ["mixed", "grouped"] },
        "sop_title": { "type": "string" },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "question_count": { "type": "string" },
            "questions_per_project": { "type": "string" },
            "house_style": { "type": "string" }
          }
        },
        "projects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "task_type"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "task_type": { "type": "string" },
              "sop_title": { "type": "string" },
              "golden_examples_used": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "question_bank": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    },
    "question_bank_quality": { "$ref": "#/$defs/question_bank_quality" },
    "worker_grading_rubric": { "$ref": "#/$defs/worker_grading_rubric" },
    "skillset": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "projects"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "projects": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "provisional": { "type": "boolean", "description": "true when no frozen skillset was supplied and these were derived this run (NOT canonical)." }
        }
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "project", "inputs", "fields", "grading", "meta"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "project": { "type": "string", "description": "Must equal one project.projects[].name." },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "prompt": { "type": "string" },
            "instruction": { "type": "string" },
            "media": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["media_id", "label", "type", "placeholder"],
                "additionalProperties": false,
                "properties": {
                  "media_id": { "type": "string", "description": "Stable id; the dev pipeline binds the emitted image part and the S3 url to the entry by this id." },
                  "label": { "type": "string" },
                  "type": { "type": "string", "enum": ["image", "video", "screenshot"] },
                  "placeholder": { "type": "string", "description": "Image brief AND the candidate-visible description; must state every deciding detail." },
                  "url": { "type": "string", "description": "EMITTED EMPTY. The dev pipeline fills the S3 link after upload, matched by media_id. Stays empty for video and for failed generations." },
                  "image_status": { "type": "string", "enum": ["pending", "verified", "failed", "real_asset", "video_no_image"], "description": "pending = generated, awaiting verification; verified = a human/independent check confirmed the image supports every graded verdict; failed = could not produce/verify (excluded from live); real_asset = a real captured asset to be attached by the pipeline; video_no_image." },
                  "key_confidence": { "type": "string", "enum": ["high", "medium", "low"] },
                  "requires_human_key_review": { "type": "boolean" }
                }
              }
            }
          }
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["key", "label", "type", "options"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["single_choice", "yes_no", "free_text"] },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "grading": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              { "$ref": "#/$defs/objective_grade" },
              { "$ref": "#/$defs/subjective_grade" }
            ]
          }
        },
        "meta": {
          "type": "object",
          "required": ["scenario_type", "answer_pattern", "difficulty", "trap"],
          "additionalProperties": false,
          "properties": {
            "scenario_type": { "type": "string" },
            "answer_pattern": { "type": "string" },
            "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
            "trap": { "type": "boolean" }
          }
        }
      }
    },
    "objective_grade": {
      "type": "object",
      "required": ["type", "answer", "reason"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "objective" },
        "answer": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "subjective_grade": {
      "type": "object",
      "required": ["type", "checklist", "constraints", "pass_condition"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "subjective" },
        "checklist": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "pass_condition": { "type": "string" }
      }
    },
    "question_bank_quality": {
      "type": "object",
      "required": ["total_questions", "per_project", "checks", "flags", "result"],
      "additionalProperties": false,
      "properties": {
        "total_questions": { "type": "integer", "minimum": 0 },
        "per_project": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["questions", "coverage"],
            "additionalProperties": false,
            "properties": {
              "questions": { "type": "integer", "minimum": 0 },
              "coverage": {
                "type": "object",
                "required": ["by_field", "patterns_present", "patterns_missing"],
                "additionalProperties": false,
                "properties": {
                  "by_field": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "additionalProperties": { "type": "integer", "minimum": 0 }
                    }
                  },
                  "patterns_present": { "type": "array", "items": { "type": "string" } },
                  "patterns_missing": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "checks": { "type": "object", "additionalProperties": { "type": "boolean" } },
        "flags": { "type": "array", "items": { "type": "string" } },
        "result": { "type": "string", "enum": ["pass", "needs_review"], "description": "Bank DESIGN quality only (coverage/ambiguity/duplication/grounding). Image render/verification is tracked separately by stimulus_status, so one flaky image does not poison the whole design result." },
        "stimulus_status": { "type": "string", "enum": ["pending", "all_verified", "some_failed"] }
      }
    },
    "worker_grading_rubric": {
      "type": "object",
      "required": ["summary", "per_project", "pass_threshold"],
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "per_project": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["dimensions"],
            "additionalProperties": false,
            "properties": {
              "dimensions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "good", "common_mistakes"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "good": { "type": "string" },
                    "common_mistakes": { "type": "array", "items": { "type": "string" } }
                  }
                }
              },
              "free_text_rubric": {
                "type": "object",
                "required": ["field", "strong", "weak", "common_mistakes"],
                "additionalProperties": false,
                "properties": {
                  "field": { "type": "string" },
                  "strong": { "type": "string" },
                  "weak": { "type": "string" },
                  "common_mistakes": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "pass_threshold": { "type": "string" }
      }
    }
  }
}
